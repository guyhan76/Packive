# 2. pdfkit 사용 현황
Write-Host "`n=== pdfkit 사용 파일 ==="
Get-ChildItem "C:\Users\user\Desktop\dev\packive\src" -Recurse -Filter "*.ts" | ForEach-Object {
    $content = Get-Content $_.FullName -Encoding UTF8 -Raw -ErrorAction SilentlyContinue
    if ($content -match "pdfkit|PDFDocument") {
        Write-Host $_.FullName.Replace("C:\Users\user\Desktop\dev\packive\", "")
    }
}
Get-ChildItem "C:\Users\user\Desktop\dev\packive\src" -Recurse -Filter "*.tsx" | ForEach-Object {
    $content = Get-Content $_.FullName -Encoding UTF8 -Raw -ErrorAction SilentlyContinue
    if ($content -match "pdfkit|PDFDocument") {
        Write-Host $_.FullName.Replace("C:\Users\user\Desktop\dev\packive\", "")
    }
}

# 3. Fabric toSVG 사용 여부
Write-Host "`n=== toSVG 사용 ==="
$f = "C:\Users\user\Desktop\dev\packive\src\components\editor\unified-editor.tsx"
